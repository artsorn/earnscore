# Optional project overrides
: ${AIA_PROFILE:=balanced}
: ${PLANNER_CLI:=codex}
: ${CODER_CLI:=codex}
: ${REVIEWER_CLI:=codex}
: ${FINAL_REVIEWER_CLI:=codex}
: ${PLANNER_MODEL:=gpt-5.6-sol}
: ${CODER_MODEL:=gpt-5.6-sol}
: ${REVIEWER_MODEL:=gpt-5.6-sol}
: ${FINAL_REVIEWER_MODEL:=gpt-5.6-sol}
: ${PLANNER_GRILL_REQUIRED:=false}
: ${CODER_SESSION_MODEL:=gpt-5.6-sol}
: ${REVIEWER_SESSION_MODEL:=gpt-5.6-sol}
: ${AGY_TIMEOUT:=30m}
: ${AGY_SANDBOX:=false}
: ${AGY_SKIP_PERMISSIONS:=true}
: ${AGY_NEW_PROJECT:=auto}
: ${AGY_MODE:=accept-edits}
: ${AGY_LOG_FILE:=off}
: ${AGY_PROJECT:=}
: ${AGY_CONVERSATION:=}
: ${AGY_CONTINUE:=false}
: ${AGY_ADD_DIRS:=}
# Optional role-specific AGY overrides. Empty values fall back to shared AGY config,
# then the generic role model/config above.
: ${PLANNER_AGY_MODEL:=}
: ${CODER_AGY_MODEL:=}
: ${REVIEWER_AGY_MODEL:=}
: ${FINAL_REVIEWER_AGY_MODEL:=}
: ${PLANNER_AGY_PROJECT:=}
: ${CODER_AGY_PROJECT:=}
: ${REVIEWER_AGY_PROJECT:=}
: ${FINAL_REVIEWER_AGY_PROJECT:=}
: ${PLANNER_AGY_CONVERSATION:=}
: ${CODER_AGY_CONVERSATION:=}
: ${REVIEWER_AGY_CONVERSATION:=}
: ${FINAL_REVIEWER_AGY_CONVERSATION:=}
: ${INLINE_CONTEXT_PACKAGE:=false}
: ${INLINE_REVIEWER_DIFF:=false}
# Codex stores no more than this many tokens from each tool/function output in model context.
: ${CODEX_TOOL_OUTPUT_TOKEN_LIMIT:=12000}
# Compact resumed history before it grows without bound; rollout budget covers the whole turn.
: ${CODEX_AUTO_COMPACT_TOKEN_LIMIT:=80000}
: ${CODEX_ROLLOUT_BUDGET_TOKENS:=160000}
# Operational logs are bounded. Exact CLI stdout remains in *.raw.log.gz for debugging.
: ${VISIBLE_LOG_MAX_LINES:=1200}
: ${VISIBLE_LOG_MAX_BYTES:=160000}
: ${VISIBLE_LOG_DIFF_MAX_LINES:=160}
: ${RAW_LOG_COMPRESSION:=gzip}
: ${MAX_ROUNDS:=3}
: ${PLANNER_TASK_DETAIL_LEVEL:=high}
: ${TASK_SIZE_AUTO:=true}
# Optional: SMALL, MEDIUM, or LARGE. Leave empty for automatic classification.
: ${TASK_SIZE_OVERRIDE:=}
: ${SMALL_PLANNER_CONTEXT_TOKENS:=15000}
: ${SMALL_CODER_CONTEXT_TOKENS:=25000}
: ${MEDIUM_PLANNER_CONTEXT_TOKENS:=30000}
: ${MEDIUM_CODER_CONTEXT_TOKENS:=50000}
: ${LARGE_PLANNER_CONTEXT_TOKENS:=80000}
: ${LARGE_CODER_CONTEXT_TOKENS:=120000}
: ${SMALL_SEARCH_BUDGET:=5}
: ${MEDIUM_SEARCH_BUDGET:=10}
: ${LARGE_SEARCH_BUDGET:=20}
: ${SMALL_CODEGRAPH_DEPTH:=1}
: ${MEDIUM_CODEGRAPH_DEPTH:=2}
: ${LARGE_CODEGRAPH_DEPTH:=3}
: ${CONTEXT_ESCALATION:=true}
: ${CONTEXT_DEFAULT_LEVEL:=auto}
: ${SMALL_MAX_CONTEXT_LEVEL:=1}
: ${MEDIUM_MAX_CONTEXT_LEVEL:=2}
: ${LARGE_MAX_CONTEXT_LEVEL:=3}
: ${ALLOW_CONTEXT_ESCALATION_ON_FAILURE:=true}
: ${ESCALATE_ON_REVIEW_FAIL:=true}
: ${ESCALATE_ON_BUILD_FAIL:=true}
: ${CONTEXT_MANIFEST:=true}
: ${SMALL_CONTEXT_TARGET_TOKENS:=25000}
: ${SMALL_CONTEXT_HARD_CAP_TOKENS:=40000}
: ${MEDIUM_CONTEXT_TARGET_TOKENS:=50000}
: ${MEDIUM_CONTEXT_HARD_CAP_TOKENS:=80000}
: ${LARGE_CONTEXT_TARGET_TOKENS:=120000}
: ${LARGE_CONTEXT_HARD_CAP_TOKENS:=160000}
: ${USE_PERSISTENT_SESSIONS:=true}
: ${PERSISTENT_SESSION_SCOPE:=task}
# Optional explicit Codex session ids. Leave unset to use saved session files.
# : ${PLANNER_SESSION:=}
# : ${CODER_SESSION:=}
# : ${REVIEWER_SESSION:=}
# : ${FINAL_REVIEWER_SESSION:=}
: ${CODEGRAPH_MODE:=smart}
: ${CODEGRAPH_DEPTH:=2}
: ${SCAN_MODE:=smart}
: ${CODEGRAPH_MAX_FILE_BYTES:=1200000}
: ${CODEGRAPH_PROJECT_MAX_LINES:=1800}
: ${TOKEN_GUARD:=true}
: ${MAX_CONTEXT_TOKENS:=50000}
: ${ALLOW_RUNTIME_LOG_READ:=false}
: ${ALLOW_HISTORY_SEARCH:=false}
: ${LAZY_KNOWLEDGE:=true}
: ${COMPACT_REVIEW:=true}
: ${SEARCH_BUDGET:=10}
: ${STRICT_SCOPE:=true}
: ${PRE_TASK_SCOPE_GATE:=true}
: ${TASK_SCOPE_CARRYOVER:=true}
: ${TASK_CHECKPOINT_ON_PASS:=true}
: ${AUTO_RESTORE_OUT_OF_SCOPE:=true}
: ${AUTO_REMOVE_OUT_OF_SCOPE_UNTRACKED:=false}

# Final reviewer failure handling:
# - stop: stop the run with non-zero exit when final review writes FAIL/BLOCKED.
# - plan-code: let Planner directly edit implementation files until the final goal is satisfied, then rerun final review.
# - review-code: let Reviewer directly edit implementation files until the final goal is satisfied, then rerun final review.
: ${FINAL_REVIEWER_FAIL_MODE:=stop}
: ${FINAL_REVIEWER_FIX_ROUNDS:=1}

# v2.3 review-scope control
# ควบคุมว่าจะรัน unit test / architecture review ในขั้นไหน
#
# FAST_REVIEW_UNIT_TEST=false (default)
#   Fast Reviewer ราย Task ไม่รัน unit test เพื่อประหยัด token
# FAST_REVIEW_UNIT_TEST=true
#   Fast Reviewer รัน unit test ทุก task (ใช้ token มากขึ้น)
: ${FAST_REVIEW_UNIT_TEST:=false}

# FAST_REVIEW_ARCHITECTURE=false (default)
#   Fast Reviewer ราย Task ไม่ทำ architecture review
# FAST_REVIEW_ARCHITECTURE=true
#   Fast Reviewer ทำ architecture review ทุก task
: ${FAST_REVIEW_ARCHITECTURE:=false}

# FINAL_REVIEW_UNIT_TEST=true (default)
#   Final Reviewer รัน unit test ตอนท้าย
# FINAL_REVIEW_UNIT_TEST=false
#   Final Reviewer ข้าม unit test (สำหรับ โปรเจ็กที่ต้องการรันเร็วมาก)
: ${FINAL_REVIEW_UNIT_TEST:=true}

# FINAL_REVIEW_ARCHITECTURE=true (default)
#   Final Reviewer ทำ architecture review ตอนท้าย
# FINAL_REVIEW_ARCHITECTURE=false
#   Final Reviewer ข้าม architecture review
: ${FINAL_REVIEW_ARCHITECTURE:=true}
