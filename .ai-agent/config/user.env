# MEDIUM task/project: recommended quality/token hybrid.
AIA_PROFILE=hybrid-efficient
TASK_SIZE_AUTO=false
TASK_SIZE_OVERRIDE=MEDIUM

PLANNER_MODEL=gpt-5.6-sol
CODER_AGY_MODEL=Gemini 3.5 Flash (Low)
REVIEWER_AGY_MODEL=Gemini 3.5 Flash (Medium)
FINAL_REVIEWER_MODEL=gpt-5.6-sol
AGY_NEW_PROJECT=auto
AGY_MODE=accept-edits
AGY_LOG_FILE=auto
AGY_TIMEOUT=45m
AGY_SKIP_PERMISSIONS=true
AGY_SANDBOX=false

PLANNER_LEVEL=high
CODER_LEVEL=high
REVIEWER_LEVEL=medium
FINAL_REVIEWER_LEVEL=high
PLANNER_TASK_DETAIL_LEVEL=high
MAX_TASKS_FROM_PLANNER=4
MAX_ROUNDS=3

MEDIUM_PLANNER_CONTEXT_TOKENS=25000
MEDIUM_CODER_CONTEXT_TOKENS=40000
MEDIUM_SEARCH_BUDGET=8
MEDIUM_CODEGRAPH_DEPTH=2
MEDIUM_MAX_CONTEXT_LEVEL=2
MEDIUM_CONTEXT_TARGET_TOKENS=45000
MEDIUM_CONTEXT_HARD_CAP_TOKENS=65000

USE_PERSISTENT_SESSIONS=true
PERSISTENT_SESSION_SCOPE=task
INLINE_CONTEXT_PACKAGE=false
FAST_REVIEW_UNIT_TEST=false
FAST_REVIEW_ARCHITECTURE=false
FINAL_REVIEW_UNIT_TEST=true
FINAL_REVIEW_ARCHITECTURE=true
RUN_FINAL_REVIEW=true
FINAL_REVIEWER_FAIL_MODE=stop
