# LARGE task/project: Codex-only, quality first.
AIA_PROFILE=balanced
TASK_SIZE_AUTO=false
TASK_SIZE_OVERRIDE=LARGE

PLANNER_CLI=codex
CODER_CLI=codex
REVIEWER_CLI=codex
FINAL_REVIEWER_CLI=codex
PLANNER_MODEL=gpt-5.6-sol
CODER_MODEL=gpt-5.6-luna
REVIEWER_MODEL=gpt-5.6-luna
FINAL_REVIEWER_MODEL=gpt-5.6-terra

PLANNER_LEVEL=high
CODER_LEVEL=medium
REVIEWER_LEVEL=medium
FINAL_REVIEWER_LEVEL=medium
PLANNER_TASK_DETAIL_LEVEL=medium
MAX_TASKS_FROM_PLANNER=8
MAX_TASKS=20
MAX_ROUNDS=3

LARGE_PLANNER_CONTEXT_TOKENS=70000
LARGE_CODER_CONTEXT_TOKENS=100000
LARGE_SEARCH_BUDGET=16
LARGE_CODEGRAPH_DEPTH=3
LARGE_MAX_CONTEXT_LEVEL=3
LARGE_CONTEXT_TARGET_TOKENS=100000
LARGE_CONTEXT_HARD_CAP_TOKENS=140000

USE_PERSISTENT_SESSIONS=true
PERSISTENT_SESSION_SCOPE=task
INLINE_CONTEXT_PACKAGE=false
FAST_REVIEW_UNIT_TEST=false
FAST_REVIEW_ARCHITECTURE=false
FINAL_REVIEW_UNIT_TEST=true
FINAL_REVIEW_ARCHITECTURE=true
RUN_FINAL_REVIEW=true
FINAL_REVIEWER_FAIL_MODE=plan-code
