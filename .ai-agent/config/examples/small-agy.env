# SMALL task/project: AGY-only.
AIA_PROFILE=agy-efficient
TASK_SIZE_AUTO=false
TASK_SIZE_OVERRIDE=SMALL

PLANNER_AGY_MODEL=Gemini 3.1 Pro (Low)
CODER_AGY_MODEL=Gemini 3.5 Flash (Low)
REVIEWER_AGY_MODEL=Gemini 3.5 Flash (Medium)
FINAL_REVIEWER_AGY_MODEL=Gemini 3.1 Pro (Low)
AGY_NEW_PROJECT=auto
AGY_MODE=accept-edits
AGY_LOG_FILE=auto
AGY_TIMEOUT=30m
AGY_SKIP_PERMISSIONS=true
AGY_SANDBOX=false

PLANNER_LEVEL=medium
CODER_LEVEL=medium
REVIEWER_LEVEL=low
FINAL_REVIEWER_LEVEL=medium
PLANNER_TASK_DETAIL_LEVEL=medium
MAX_TASKS_FROM_PLANNER=1
MAX_ROUNDS=2

SMALL_PLANNER_CONTEXT_TOKENS=12000
SMALL_CODER_CONTEXT_TOKENS=18000
SMALL_SEARCH_BUDGET=4
SMALL_CODEGRAPH_DEPTH=1
SMALL_MAX_CONTEXT_LEVEL=1
SMALL_CONTEXT_TARGET_TOKENS=18000
SMALL_CONTEXT_HARD_CAP_TOKENS=28000

INLINE_CONTEXT_PACKAGE=false
FAST_REVIEW_UNIT_TEST=false
FAST_REVIEW_ARCHITECTURE=false
FINAL_REVIEW_UNIT_TEST=true
FINAL_REVIEW_ARCHITECTURE=false
RUN_FINAL_REVIEW=true
FINAL_REVIEWER_FAIL_MODE=stop
