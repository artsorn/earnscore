{
  "name": "earnscore-dashboard",
  "version": "1.0.0",
  "description": "Cloudflare Workers live dashboard for AiScore data sync",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev --port 8080",
    "deploy": "wrangler deploy",
    "d1:init": "wrangler d1 execute earnscore-db --local --file=schema.sql",
    "d1:init:prod": "wrangler d1 execute earnscore-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.60.0"
  }
}
